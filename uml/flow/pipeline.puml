@startuml
title Request pipeline — HTTP proxy + (optional) replication
hide footbox
autonumber

actor Client
participant "ProxyMiddleware" as MW
participant "ProxyRequestUseCase" as UC
participant "BRSParser" as P
participant "ChooseNodeUseCase" as CH
participant "MetricsRepository" as MR
participant "NodeRegistry" as NR
participant "ReplicationManager" as RM
participant "ReplicationPlanner" as RP
participant "ReplicationRunner" as RR
participant "CompletionPolicy" as CP
participant "Target Node" as TN

Client -> MW : HTTP request
MW -> UC : execute(request)
UC -> P : parse(headers)
P --> UC : BRSRequest

alt replication enabled\n(replicate_all OR count OR strategy)
  UC -> RM : execute(request, brs)
  RM -> RP : build(brs)
  RP -> CH : rank_nodes(brs)
  CH -> MR : list_latest()
  CH -> MR : get_prev(node_id)*
  CH -> NR : get_endpoint(node_id)*
  CH --> RP : ranked nodes
  RP --> RM : ReplicationPlan

  RM -> CP : get(policy,k)
  RM -> RR : execute(cmd, plan, policy, deadline)
  loop replicas
    RR -> TN : HTTP call (delayed if needed)
    TN --> RR : response
    RR -> CP : push(reply)
  end
  RR --> RM : ExecutionResult(winner)
  RM -> MR : add_latency(winner.node, ms)
  RM --> UC : Response
else no replication
  UC -> CH : execute(brs)
  CH -> MR : list_latest()
  CH -> MR : get_prev(node_id)*
  CH -> NR : get_endpoint(node_id)
  CH --> UC : (node_id, host, port)

  UC -> TN : HTTP request
  TN --> UC : response
  UC -> MR : add_latency(node_id, ms)
end

UC --> MW : ProxyResult
MW --> Client : HTTP response
@enduml